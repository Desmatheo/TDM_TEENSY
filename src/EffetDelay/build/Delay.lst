 123:Delay.cpp     **** float DelayEffect::DelayChannel::Process(float in) {
 124:Delay.cpp     ****     if (!buffer) return in;
 125:Delay.cpp     **** 
 126:Delay.cpp     ****     // Lissage du temps de delay pour éviter les clics (équivalent local de fonepole)
 127:Delay.cpp     ****     currentDelay += 0.0002f * (delayTarget - currentDelay);
 128:Delay.cpp     **** 
 129:Delay.cpp     ****     // Lecture du son retardé avec interpolation linéaire
 130:Delay.cpp     ****     float read_idx_f = (float)write_idx - currentDelay;
 131:Delay.cpp     ****     while (read_idx_f < 0.0f) read_idx_f += (float)buf_len;
 132:Delay.cpp     ****     while (read_idx_f >= (float)buf_len) read_idx_f -= (float)buf_len;
 133:Delay.cpp     **** 
 134:Delay.cpp     ****     uint32_t r0 = (uint32_t)read_idx_f;
 135:Delay.cpp     ****     uint32_t r1 = r0 + 1; 
 136:Delay.cpp     ****     if (r1 >= buf_len) r1 = 0;
 137:Delay.cpp     ****     float frac = read_idx_f - (float)r0;
 138:Delay.cpp     **** 
 139:Delay.cpp     ****     float del_read = buffer[r0] + (buffer[r1] - buffer[r0]) * frac;
 140:Delay.cpp     **** 
 141:Delay.cpp     ****     // Application du filtre passe-bas
 142:Delay.cpp     ****     float read = tone_a0 * del_read + tone_b1 * tone_z1;
 143:Delay.cpp     ****     tone_z1 = read;
 144:Delay.cpp     **** 
 145:Delay.cpp     ****     // Écriture dans la ligne de delay (avec feedback)
 146:Delay.cpp     ****     float write_val = feedback * read;
 147:Delay.cpp     ****     if (active) {
 148:Delay.cpp     ****         write_val += in;
 149:Delay.cpp     ****     }
 150:Delay.cpp     ****     
ARM GAS  /tmp/cc4PvTAY.s 			page 38


 151:Delay.cpp     ****     // Limiteur de saturation interne
 152:Delay.cpp     ****     if (write_val > 1.0f) write_val = 1.0f;
 153:Delay.cpp     ****     if (write_val < -1.0f) write_val = -1.0f;
 154:Delay.cpp     ****     
 155:Delay.cpp     ****     buffer[write_idx] = write_val;
 156:Delay.cpp     **** 
 157:Delay.cpp     ****     write_idx++;
 158:Delay.cpp     ****     if (write_idx >= buf_len) write_idx = 0;
 159:Delay.cpp     **** 
 160:Delay.cpp     ****     return read;
 161:Delay.cpp     **** }

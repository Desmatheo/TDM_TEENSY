  30:Delay.cpp     **** 
  31:Delay.cpp     ****     // Lecture du son retardé
  32:Delay.cpp     ****     float del_read = del->Read();
  33:Delay.cpp     **** 
  34:Delay.cpp     ****     // Application du filtre passe-bas
  35:Delay.cpp     ****     float read = tone.Process(del_read); 
  36:Delay.cpp     **** 
  37:Delay.cpp     ****     // Écriture dans la ligne de delay (avec feedback)
  38:Delay.cpp     ****     if (active) {
  39:Delay.cpp     ****         del->Write((feedback * read) + in);
  40:Delay.cpp     ****     } else {
  41:Delay.cpp     ****         del->Write(feedback * read);                // Si inactif, seul le feedback est réinjecté
  42:Delay.cpp     ****     }
  43:Delay.cpp     **** 
  44:Delay.cpp     ****     return read;
  45:Delay.cpp     **** }

  57:Delay.cpp     **** 
  58:Delay.cpp     **** void DelayEffect::update(const float** in, float** out, int idx) {
  59:Delay.cpp     ****     float inputL = in[0][idx];
  60:Delay.cpp     ****     float inputR = in[1][idx];
  61:Delay.cpp     **** 
  62:Delay.cpp     **** 
  63:Delay.cpp     ****     // Traitement du son par les lignes de delay
  64:Delay.cpp     ****     float delay_outL = delayL.Process(inputL);
  65:Delay.cpp     ****     float delay_outR = delayR.Process(inputR);
  66:Delay.cpp     **** 
  67:Delay.cpp     ****     // Mixage du son original (dry) et du son traité (wet)
  68:Delay.cpp     ****     out[0][idx] = inputL * dryMix + delay_outL * wetMix * volume;
  69:Delay.cpp     ****     out[1][idx] = inputR * dryMix + delay_outR * wetMix * volume;
  70:Delay.cpp     **** }

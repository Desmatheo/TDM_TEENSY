  81:Delay.cpp     **** void DelayEffect::DelayChannel::Init(float sampleRate, uint32_t max_delay_samples) {
  82:Delay.cpp     ****     buf_len = max_delay_samples;
  83:Delay.cpp     ****     
  84:Delay.cpp     ****     // Allocation en priorité sur la PSRAM (extmem_malloc)
  85:Delay.cpp     ****     // 4s * 2 (stéréo) * 6 cordes = ~8.4 Mo, impossible sur la RAM interne !
  86:Delay.cpp     ****     buffer = (float*)extmem_malloc(buf_len * sizeof(float));
  87:Delay.cpp     ****     if (buffer) {
  88:Delay.cpp     ****         use_extmem = true;
  89:Delay.cpp     ****     } else {
  90:Delay.cpp     ****         buffer = (float*)malloc(buf_len * sizeof(float));
  91:Delay.cpp     ****         use_extmem = false;
  92:Delay.cpp     ****     }
  93:Delay.cpp     **** 
ARM GAS  /tmp/cc4PvTAY.s 			page 37


  94:Delay.cpp     ****     if (buffer) {
  95:Delay.cpp     ****         memset(buffer, 0, buf_len * sizeof(float));
  96:Delay.cpp     ****     }
  97:Delay.cpp     ****     write_idx = 0;
  98:Delay.cpp     ****     
  99:Delay.cpp     ****     // Initialisation du filtre Tone (Low-pass 1-pole) à 3000 Hz
 100:Delay.cpp     ****     float tone_hz = 3000.0f;
 101:Delay.cpp     ****     float alpha = expf(-2.0f * (float)PI * tone_hz / sampleRate);
 102:Delay.cpp     ****     tone_a0 = 1.0f - alpha;
 103:Delay.cpp     ****     tone_b1 = alpha;
 104:Delay.cpp     ****     tone_z1 = 0.0f;
 105:Delay.cpp     **** 
 106:Delay.cpp     ****     currentDelay = 2400.0f;
 107:Delay.cpp     ****     delayTarget = 2400.0f;
 108:Delay.cpp     ****     feedback = 0.5f;
 109:Delay.cpp     ****     active = true;
 110:Delay.cpp     **** }

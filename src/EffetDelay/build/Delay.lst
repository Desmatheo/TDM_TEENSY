 184:Delay.cpp     **** void DelayEffect::update() {
 185:Delay.cpp     ****     audio_block_t* inL = receiveReadOnly(0);
 186:Delay.cpp     ****     audio_block_t* inR = receiveReadOnly(1);
 187:Delay.cpp     **** 
 188:Delay.cpp     ****     if (!inL && !inR) return;
 189:Delay.cpp     ****     
 190:Delay.cpp     ****     if (!active || (!delayL.buffer && !delayR.buffer)) {
 191:Delay.cpp     ****         if (inL) { transmit(inL, 0); release(inL); }
 192:Delay.cpp     ****         if (inR) { transmit(inR, 1); release(inR); }
 193:Delay.cpp     ****         return;
 194:Delay.cpp     ****     }
 195:Delay.cpp     **** 
 196:Delay.cpp     ****     audio_block_t* outL = allocate();
 197:Delay.cpp     ****     audio_block_t* outR = allocate();
 198:Delay.cpp     **** 
 199:Delay.cpp     ****     if (!outL || !outR) {
 200:Delay.cpp     ****         if (outL) release(outL);

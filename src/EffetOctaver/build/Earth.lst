  29:../../lib/Q/q_lib/include/q/fx/biquad.hpp **** 
  30:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****       float operator()(float s)
  31:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****       {
  32:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          // compute result
  33:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          auto r = a0 * s + a1 * x1 + a2 * x2 - a3 * y1 - a4 * y2;
  34:../../lib/Q/q_lib/include/q/fx/biquad.hpp **** 
  35:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          // shift x1 to x2, s to x1
  36:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          x2 = x1;
  37:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          x1 = s;
  38:../../lib/Q/q_lib/include/q/fx/biquad.hpp **** 
  39:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          // shift y1 to y2, r to y1
  40:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          y2 = y1;
  41:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          y1 = r;
  42:../../lib/Q/q_lib/include/q/fx/biquad.hpp **** 
  43:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****          return r;
  44:../../lib/Q/q_lib/include/q/fx/biquad.hpp ****       }

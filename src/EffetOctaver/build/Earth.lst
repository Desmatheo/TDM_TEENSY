  90:Util/BandShifter.h ****     // Octave shifts are performed via phase scaling described in "Real-Time
  91:Util/BandShifter.h ****     // Polyphonic Octave Doubling for the Guitar" by Etienne Thuillier
  92:Util/BandShifter.h ****     // https://core.ac.uk/download/pdf/80719011.pdf
  93:Util/BandShifter.h ****     //
  94:Util/BandShifter.h ****     // in = complex input signal
  95:Util/BandShifter.h ****     // out = scaled complex output signal
  96:Util/BandShifter.h ****     // g = scaling factor
  97:Util/BandShifter.h ****     //
  98:Util/BandShifter.h ****     // out = in * (in / |in|)^(g - 1)
  99:Util/BandShifter.h ****     //
 100:Util/BandShifter.h ****     // Note that for octave down (g = 1/2), it is necessary to detect phase
 101:Util/BandShifter.h ****     // transitions in order to set the sign of the output signal.
